	-rm -f ./$(DEPDIR)/libgnu_la-msvc-nothrow.Plo
	-rm -f ./$(DEPDIR)/libgnu_la-relocatable.Plo
	-rm -f ./$(DEPDIR)/libgnu_la-unistd.Plo
	-rm -f Makefile
distclean-am: clean-am distclean-compile distclean-generic \
