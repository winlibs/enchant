	-$(am__rm_f) dictionary/$(am__dirstamp)
	-$(am__rm_f) provider/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) provider/$(am__dirstamp)
	-$(am__rm_f) providers/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) providers/$(am__dirstamp)
	-$(am__rm_f) providers/dictionary/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) providers/dictionary/$(am__dirstamp)
